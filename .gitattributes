# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Config files
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files (don't try to merge, don't normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# FAISS index files (binary, large)
*.faiss binary
*.index binary

# Python compiled files (binary)
*.pyc binary
*.pyo binary
*.pyd binary

# Database files (binary)
*.db binary
*.sqlite binary
*.sqlite3 binary

# Mark large files for Git LFS (if using LFS)
# *.faiss filter=lfs diff=lfs merge=lfs -text
# *.json filter=lfs diff=lfs merge=lfs -text

