# ## Dependencies ##
# Ignore the massive folder of downloaded JavaScript libraries
node_modules/

# Ignore the Python virtual environment folder
.venv/

# ## Sensitive Information ##
# [cite_start]Ignore all environment files containing API keys or secrets [cite: 90]
.env
*.env.local

# ## Python Cache ##
# Ignore Python's auto-generated cache folders and files
__pycache__/
*.pyc

# ## Data ##
# Ignore the large raw datasets to keep the repository small
datasets/

# ## Build Output ##
# Ignore the production build folders
dist
dist-ssr

# ## Log Files ##
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ## IDE & OS Files ##
# Ignore IDE-specific settings and OS junk files
.idea/
.vscode/
.DS_Store