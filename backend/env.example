# OmniLens Backend Environment Variables
# Copy this file to .env and fill in your actual API keys

# VirusTotal API Key (v3)
# Get yours at: https://www.virustotal.com/gui/my-apikey
VT_API_KEY=your_virustotal_api_key_here

# URLHaus API Key (optional but recommended for higher rate limits)
# Get yours at: https://urlhaus.abuse.ch/api/#account
URLHAUS_API_KEY=your_urlhaus_api_key_here

# FAISS Configuration (optional, defaults shown)
# Number of neighbors to retrieve
FAISS_K=8

# Softmax temperature for neighbor weighting
FAISS_TAU=10.0

# API Server Configuration (optional)
# HOST=0.0.0.0
# PORT=8000

